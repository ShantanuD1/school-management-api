{
  "info": {
    "name": "School Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Greenwood High\",\n  \"address\": \"123 Main St\",\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        }
      },
      "response": []
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=12.9716&longitude=77.5946",
          "host": ["{{baseUrl}}"],
          "path": ["listSchools"],
          "query": [
            { "key": "latitude", "value": "12.9716" },
            { "key": "longitude", "value": "77.5946" }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ]
}
